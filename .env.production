# 生产环境非敏感配置。真实凭据应由部署平台或操作系统环境变量注入。
# ENV=production 会启用 PostgreSQL 类型校验。
# DATABASE_URL 不应写入本文件；postgresql+psycopg:// 可同时支持 SQLAlchemy 异步引擎。
# PROJECT_TITLE 会显示在生产环境的 OpenAPI 文档中。
ENV=production
# DATABASE_URL 必须由生产运行环境提供。
# 格式示例：postgresql+psycopg://<用户名>:<密码>@<主机>:5432/<数据库名>

PROJECT_TITLE = 生产环境项目标题
